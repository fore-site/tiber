# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tiber
# Sync URL for Alembic migrations (psycopg2 driver)
DATABASE_SYNC_URL=postgresql+psycopg2://user:password@localhost:5432/tiber

# RabbitMQ
RABBITMQ_URL=amqp://user:password@localhost:5672/
CELERY_BROKER_URL=amqp://user:password@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Redis
# DB 0: JWT blocklist, API key revocation, rate limiting, idempotency keys
REDIS_URL=redis://localhost:6379/0

# Auth
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# Rate Limiting
RATE_LIMIT_REQUESTS=limit
RATE_LIMIT_WINDOW_SECONDS=window

# Idempotency
IDEMPOTENCY_TTL_SECONDS=

# Object Storage 
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_MODELS=tiber-models
STORAGE_BUCKET_DATASETS=tiber-datasets
STORAGE_SECURE=false

# Observability
# Leave empty to disable OTLP export
OTLP_ENDPOINT=http://localhost:4318

# AI Providers
GROQ_API_KEY=
GEMINI_API_KEY=

# Email Provider
# Options: resend | sendgrid | mock
EMAIL_PROVIDER=mock
RESEND_API_KEY=
SENDGRID_API_KEY=

# Push Provider
# Options: fcm | mock
PUSH_PROVIDER=mock
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=